# GramPulse SaaS — variables d'environnement

# Whop — GramPulse Pro (https://whop.com/vag-agency-limited/grampulse-pro)
WHOP_API_KEY=apik_...
WHOP_WEBHOOK_SECRET=whsec_...
WHOP_PLAN_ID=plan_duJvdhlQGgfDY
WHOP_PRODUCT_ID=prod_dJcY2U9SHlGwh
# WHOP_CHECKOUT_URL=https://whop.com/vag-agency-limited/grampulse-pro
WHOP_RETURN_URL=https://grampulse.app/account?checkout=success

# Provider Instagram : auto (défaut), hiker, apify, mock
INSTAGRAM_PROVIDER=auto
MOCK_INSTAGRAM=auto

# HikerAPI — recommandé (~0,002 $/compte)
HIKERAPI_ACCESS_KEY=
HIKER_POSTS_LIMIT=25

# Apify — fallback optionnel
APIFY_API_TOKEN=
APIFY_INSTAGRAM_ACTOR=aurican/instagram-creator-insights-api
APIFY_POSTS_LIMIT=25

# Linkscale — tracking des clics
LINKSCALE_API_KEY=
LINKSCALE_TIMEZONE=Europe/Paris

# URLs (prod)
APP_URL=http://localhost:3000
ALLOWED_ORIGINS=https://grampulse.com,https://www.grampulse.com
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base SQLite (prod Render : /var/data/grampulse.db via render.yaml)
# GRAMPULSE_DB=

# Affichage abonnement
GRAMPULSE_PLAN_LABEL=GramPulse Pro
GRAMPULSE_PRICE_LABEL=99 €/mois

# Limite comptes par modèle
MAX_ACCOUNTS_PER_MODEL=20

# Dev only — bypass paiement en local (laisse vide en prod)
DEV_BYPASS_EMAIL=toi@exemple.com
